<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:TravelGuideApp.Models"
             x:Class="TravelGuideApp.Views.FavoritesPage"
             Title="Yêu thích"
             BackgroundColor="#F5F6F8">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <Label Text="Điểm đến yêu thích" FontSize="18" FontAttributes="Bold" />
            <CollectionView ItemsSource="{Binding FavoritePois}" SelectionMode="Single" SelectedItem="{Binding SelectedPoi, Mode=TwoWay}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:POI">
                        <Frame HasShadow="False" CornerRadius="12" Padding="12" Margin="0,0,0,10" BackgroundColor="White" BorderColor="#F3F4F6">
                            <VerticalStackLayout>
                                <Label Text="{Binding Name}" FontAttributes="Bold" />
                                <Label Text="{Binding Description}" FontSize="12" TextColor="#6B7280" MaxLines="2"/>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="Tour yêu thích" FontSize="18" FontAttributes="Bold" />
            <CollectionView ItemsSource="{Binding FavoriteTours}" SelectionMode="Single" SelectedItem="{Binding SelectedTour, Mode=TwoWay}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Tour">
                        <Frame HasShadow="False" CornerRadius="12" Padding="12" Margin="0,0,0,10" BackgroundColor="White" BorderColor="#F3F4F6">
                            <VerticalStackLayout>
                                <Label Text="{Binding Name}" FontAttributes="Bold" />
                                <Label Text="{Binding Description}" FontSize="12" TextColor="#6B7280" MaxLines="2"/>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
