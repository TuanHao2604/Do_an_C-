<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:TravelGuideApp.ViewModels"
             x:Class="TravelGuideApp.Views.TourDetailPage"
             Title="{Binding Title}"
             BackgroundColor="#F5F6F8">

    <Grid RowDefinitions="Auto, *">
        <VerticalStackLayout Grid.Row="0" Padding="20,20,20,10" Spacing="8">
            <Label Text="{Binding Tour.Name}" FontSize="24" FontAttributes="Bold" TextColor="#111827"/>
            <Label Text="{Binding LocalizedDescription}" FontSize="14" TextColor="#6B7280"/>
            <Label Text="{Binding Tour.EstimatedTime, StringFormat='Thời gian ước tính: {0}'}" FontSize="12" TextColor="#6B7280"/>
            <Button Text="{Binding IsFavorite, Converter={StaticResource FavoriteTextConverter}}"
                    Command="{Binding ToggleFavoriteCommand}"
                    BackgroundColor="#EFF6FF"
                    TextColor="#1D4ED8"
                    CornerRadius="25"
                    FontAttributes="Bold"
                    HeightRequest="44"/>
            <Button Text="Bắt đầu tour"
                    Command="{Binding StartTourCommand}"
                    BackgroundColor="#1D4ED8"
                    TextColor="White"
                    CornerRadius="25"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    Margin="0,10,0,0"/>
            <Button Text="Đánh giá tour"
                    Command="{Binding ReviewCommand}"
                    BackgroundColor="#EFF6FF"
                    TextColor="#1D4ED8"
                    CornerRadius="25"
                    FontAttributes="Bold"
                    HeightRequest="44"
                    Margin="0,6,0,0"/>
        </VerticalStackLayout>

        <Frame Grid.Row="1" Margin="20,10" CornerRadius="18" BackgroundColor="White" HasShadow="False">
            <VerticalStackLayout Spacing="12">
                <Label Text="Danh sách điểm đến" FontSize="18" FontAttributes="Bold" TextColor="#111827"/>
                <CollectionView ItemsSource="{Binding TourPois}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:TourPoiItem">
                            <Grid ColumnDefinitions="30, 50, *" Padding="5">
                                <Label Text="{Binding OrderIndex}" FontAttributes="Bold" TextColor="#1D4ED8" VerticalOptions="Center"/>
                                <Frame HeightRequest="50" WidthRequest="50" CornerRadius="12" Padding="0" Grid.Column="1" IsClippedToBounds="True">
                                    <Image Source="poi_placeholder.jpg" Aspect="AspectFill" />
                                </Frame>
                                <VerticalStackLayout Grid.Column="2" Margin="10,0,0,0" Spacing="2">
                                    <Label Text="{Binding Poi.Name}" FontAttributes="Bold" FontSize="14" TextColor="#111827"/>
                                    <Label Text="{Binding Poi.Description}" FontSize="12" TextColor="#6B7280" MaxLines="2" LineBreakMode="TailTruncation"/>
                                </VerticalStackLayout>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </Frame>

        <ActivityIndicator IsVisible="{Binding IsBusy}" IsRunning="{Binding IsBusy}" Grid.RowSpan="2" HorizontalOptions="Center" VerticalOptions="Center" />
    </Grid>
</ContentPage>
