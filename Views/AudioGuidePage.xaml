<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:TravelGuideApp.ViewModels"
             x:Class="TravelGuideApp.Views.AudioGuidePage"
             Title="{Binding Title}">

    <VerticalStackLayout Spacing="30" Padding="20" VerticalOptions="Center">

        <Label Text="🎧 Audio Guide"
               FontSize="32"
               HorizontalOptions="Center" 
               FontAttributes="Bold"/>

        <Label Text="{Binding StatusText}"
               FontSize="18"
               HorizontalOptions="Center" />

        <HorizontalStackLayout Spacing="20" HorizontalOptions="Center">
            <Button Text="Resume" Command="{Binding PlayAudioCommand}" />
            <Button Text="Stop" Command="{Binding StopAudioCommand}" BackgroundColor="Red" />
        </HorizontalStackLayout>

    </VerticalStackLayout>
</ContentPage>
