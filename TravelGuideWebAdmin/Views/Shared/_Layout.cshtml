<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TravelGuideWebAdmin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@500;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TravelGuideWebAdmin.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <header class="app-header">
            <nav class="navbar navbar-expand-lg navbar-dark app-navbar">
                <div class="container">
                    <a class="navbar-brand app-brand fw-bold fs-4" asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-compass-fill me-2"></i>TravelGuide <span>Admin</span>
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="mainNav">
                        <div class="navbar-nav ms-auto gap-2">
                            @if (User?.Identity?.IsAuthenticated ?? false)
                            {
                                <a class="nav-link app-nav-link" asp-area="" asp-controller="Home" asp-action="Index"><i class="bi bi-house-door me-2"></i>Trang chủ</a>
                                <a class="nav-link app-nav-link" asp-area="" asp-controller="POIs" asp-action="Index"><i class="bi bi-geo-alt me-2"></i>POI</a>
                                <a class="nav-link app-nav-link" asp-area="" asp-controller="Tours" asp-action="Index"><i class="bi bi-signpost-split me-2"></i>Tour</a>
                                <a class="nav-link app-nav-link" asp-area="" asp-controller="Users" asp-action="Index"><i class="bi bi-people me-2"></i>Người dùng</a>
                            }
                        </div>
                        <div class="ms-lg-3 mt-3 mt-lg-0">
                            @if (User?.Identity?.IsAuthenticated ?? false)
                            {
                                <div class="d-flex align-items-center gap-2">
                                    <a class="btn btn-primary" asp-area="" asp-controller="POIs" asp-action="Create">
                                        <i class="bi bi-plus-circle me-2"></i>Thêm POI
                                    </a>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-outline" type="submit">Đăng xuất</button>
                                    </form>
                                </div>
                            }
                            else
                            {
                                <a class="btn btn-primary" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                            }
                        </div>
                    </div>
                </div>
            </nav>
        </header>
        <main role="main" class="container app-main">
            @RenderBody()
        </main>
        <footer class="app-footer">
            <div class="container d-flex flex-wrap justify-content-between align-items-center gap-2">
                <span>&copy; 2026 TravelGuideWebAdmin. Nhanh, rõ ràng, dễ quản trị.</span>
                <span>Version 1.0</span>
            </div>
        </footer>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
